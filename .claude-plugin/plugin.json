{
  "name": "@cyanheads/national-parks-mcp-server",
  "version": "0.1.1",
  "description": "Plan US National Park Service trips — find parks, check alerts and closures, find campgrounds, browse things to do and events via the NPS Data API.",
  "author": {
    "name": "Casey Hand"
  },
  "homepage": "https://github.com/cyanheads/national-parks-mcp-server#readme",
  "repository": "https://github.com/cyanheads/national-parks-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/national-parks-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/national-parks-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "NPS_API_KEY": "your-api-key"
      }
    }
  }
}
